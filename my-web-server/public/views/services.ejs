<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Danh sách Dịch Vụ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

  <div class="container mt-5">
    <h1 class="text-center mb-4">Danh sách Dịch Vụ</h1>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="/home">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/services">Services</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/product">Product</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/bookings">Booking</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/doanhthu">Doanh Thu</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/HoaDon">HoaDon</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
    <div class="table-responsive">
      <table class="table table-striped table-bordered table-hover">
        <thead>
          <tr>
            <th>ID</th>
            <th>Tên Dịch Vụ</th>
            <th>Giá</th>
            <th>Mô Tả</th>
            <th>Thời Gian</th>
            <th>Hoạt Động</th>
            <th>Sửa</th>
            <th>Xóa</th>
          </tr>
        </thead>
        <tbody>
          <% if (services.length > 0) { %>
            <% services.forEach(service => { %>
              <tr>
                <td><%= service.idDichVu %></td>
                <td><%= service.tenDichVu %></td>
                <td><%= service.gia %> VNĐ</td>
                <td>
                  <!-- Nút để mở/thu gọn mô tả -->
                  <button class="btn btn-info btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#description-<%= service.idDichVu %>" aria-expanded="false" aria-controls="description-<%= service.idDichVu %>">
                    Xem mô tả
                  </button>

                  <!-- Phần mô tả có id riêng biệt -->
                  <div class="collapse description-collapse" id="description-<%= service.idDichVu %>">
                    <p><%= service.moTa %></p>
                  </div>
                </td>
                <td><%= service.thoiGian %></td>
                <td><%= service.hoatDong ? 'Đang hoạt động' : 'Ngừng hoạt động' %></td>
                <td>
                    <a href="/services/edit-service/<%= service.idDichVu %>" class="btn btn-warning btn-sm">Sửa</a>            
                </td>
                <td>
                  <form action="/services/delete-service/<%= service.idDichVu %>" method="POST" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                    <button type="submit" class="btn btn-outline-danger">Xóa</button>
                  </form>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="8" class="text-center">Không có dịch vụ nào hiện có.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
