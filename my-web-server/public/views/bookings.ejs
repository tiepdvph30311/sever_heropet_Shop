<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Danh sách Booking</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
  <div class="container mt-5">
    <h1 class="text-center mb-5">Danh sách Booking</h1>
    
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-4">
      <div class="container-fluid">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
          aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link active" aria-current="page" href="/home">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/services">Services</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/product">Product</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/bookings">Booking</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/doanhthu">Doanh Thu</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/HoaDon">HoaDon</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Table booking -->
    <div class="table-responsive">
      <table class="table table-bordered table-striped table-hover">
        <thead class="table-dark">
          <tr>
            <th>Cân Nặng</th>
            <th>ID User</th>
            <th>Loại Thú Cưng</th>
            <th>Tên Dịch Vụ</th>
            <th>Tên Thú Cưng</th>
            <th>Thời Gian Đặt Lịch</th>
            <th>Trạng Thái</th>
            <th>Hành Động</th>
          </tr>
        </thead>
        <tbody>
          <% if (bookings.length > 0) { %>
            <% bookings.forEach(booking => { %>
              <tr>
                <td><%= booking.canNang %></td>
                <td><%= booking.iduser %></td>
                <td><%= booking.loaiThuCung %></td>
                <td><%= booking.tenDichVu %></td>
                <td><%= booking.tenThuCung %></td>
                <td><%= booking.thoiGianDatLich.toDate().toLocaleString() %></td>
                <td><%= booking.trangThai %></td>
                <td>
                  <!-- Sửa booking -->
                  <a href="/bookings/editBooking/<%= booking.idcthdbooking %>" class="btn btn-success btn-sm">Sửa</a>
                  <!-- Xóa booking -->
                  <a href="/bookings/deleteBooking/<%= booking.idcthdbooking %>" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc chắn muốn xóa booking này?')">Xóa</a>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="8" class="text-center text-muted">Không có booking nào.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
